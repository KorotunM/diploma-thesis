# Shared application metadata
APP_ENV=local
APP_VERSION=0.1.0

# PostgreSQL server and application connection defaults
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aggregator
POSTGRES_USER=aggregator
POSTGRES_PASSWORD=aggregator
POSTGRES_DRIVER=psycopg
POSTGRES_APPLICATION_NAME=diploma-thesis
POSTGRES_CONNECT_TIMEOUT_SECONDS=5
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT_SECONDS=30
POSTGRES_POOL_RECYCLE_SECONDS=1800
POSTGRES_POOL_PRE_PING=true

# RabbitMQ broker and management defaults
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_DEFAULT_USER=aggregator
RABBITMQ_DEFAULT_PASS=aggregator
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_HEARTBEAT_SECONDS=30
RABBITMQ_CONNECTION_TIMEOUT_SECONDS=5
RABBITMQ_PREFETCH_COUNT=16
RABBITMQ_PUBLISH_RETRY=true
RABBITMQ_PUBLISH_RETRY_MAX_RETRIES=3

# MinIO API and bootstrap credentials
MINIO_ENDPOINT=http://minio:9000
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=aggregator
MINIO_ROOT_PASSWORD=aggregator-secret
MINIO_SECURE=false
MINIO_REGION=us-east-1

# Grafana local bootstrap credentials
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
